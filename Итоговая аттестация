import tkinter as tk
from tkinter import ttk, messagebox, filedialog
import json

class BookTracker:
    def __init__(self, root):
        self.root = root
        self.root.title("Book Tracker")

        # Поля для ввода
        tk.Label(root, text="Название книги").grid(row=0, column=0)
        self.title_entry = tk.Entry(root)
        self.title_entry.grid(row=0, column=1)

        tk.Label(root, text="Автор").grid(row=1, column=0)
        self.author_entry = tk.Entry(root)
        self.author_entry.grid(row=1, column=1)

        tk.Label(root, text="Жанр").grid(row=2, column=0)
        self.genre_entry = tk.Entry(root)
        self.genre_entry.grid(row=2, column=1)

        tk.Label(root, text="Кол-во страниц").grid(row=3, column=0)
        self.pages_entry = tk.Entry(root)
        self.pages_entry.grid(row=3, column=1)

        # Кнопка добавления
        tk.Button(root, text="Добавить книгу", command=self.add_book).grid(row=4, column=0, columnspan=2)

        # Treeview для отображения
        self.tree = ttk.Treeview(root, columns=("Название", "Автор", "Жанр", "Страницы"), show='headings')
        for col in self.tree["columns"]:
            self.tree.heading(col, text=col)
        self.tree.grid(row=5, column=0, columnspan=2)

        # Кнопки сохранения/загрузки
        tk.Button(root, text="Сохранить в JSON", command=self.save_to_json).grid(row=6, column=0)
        tk.Button(root, text="Загрузить из JSON", command=self.load_from_json).grid(row=6, column=1)

    def add_book(self):
        title = self.title_entry.get()
        author = self.author_entry.get()
        genre = self.genre_entry.get()
        pages = self.pages_entry.get()

        # Проверка
        if not title or not author or not genre or not pages:
            messagebox.showerror("Ошибка", "Все поля должны быть заполнены")
            return
        if not pages.isdigit():
            messagebox.showerror("Ошибка", "Количество страниц должно быть числом")
            return

        self.tree.insert('', 'end', values=(title, author, genre, pages))
        # Очистка полей
        self.title_entry.delete(0, tk.END)
        self.author_entry.delete(0, tk.END)
        self.genre_entry.delete(0, tk.END)
        self.pages_entry.delete(0, tk.END)

    def save_to_json(self):
        data = []
        for item in self.tree.get_children():
            data.append(self.tree.item(item)['values'])
        with open('books.json', 'w', encoding='utf-8') as f:
            json.dump(data, f, ensure_ascii=False, indent=4)

    def load_from_json(self):
        try:
            with open('books.json', 'r', encoding='utf-8') as f:
                data = json.load(f)
            self.tree.delete(*self.tree.get_children())
            for book in data:
                self.tree.insert('', 'end', values=book)
        except FileNotFoundError:
            messagebox.showinfo("Инфо", "Файл books.json не найден")

if __name__ == "__main__":
    root = tk.Tk()
    app = BookTracker(root)
    root.mainloop()
